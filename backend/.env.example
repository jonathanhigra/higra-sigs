DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change_me
DB_NAME=higra_sigs
# Opcional. Se vazio, a aplicação usa DB_HOST/DB_PORT/DB_USER/DB_PASSWORD/DB_NAME.
DATABASE_URL=
# Deixe vazio para autodetectar:
# - disable para Postgres local
# - require para RDS/acesso remoto, inclusive via SSH tunnel
DB_SSL=

# Túnel SSH automático para RDS (desenvolvimento local)
# Use quando DB_HOST/DB_PORT apontarem para localhost e você quiser
# evitar abrir o túnel manualmente a cada execução.
AUTO_DB_TUNNEL=false
DB_TUNNEL_SSH_HOST=
DB_TUNNEL_SSH_USER=ec2-user
DB_TUNNEL_SSH_KEY=
DB_TUNNEL_REMOTE_HOST=
DB_TUNNEL_REMOTE_PORT=5432
DB_TUNNEL_LOCAL_HOST=127.0.0.1
DB_TUNNEL_LOCAL_PORT=5433

JWT_SECRET_KEY=change_me_to_a_strong_secret
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=1440

# Claude API (obrigatório)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

CHAT_PROVIDER=local
N8N_CHAT_WEBHOOK_URL=
N8N_CHAT_BEARER_TOKEN=
N8N_CHAT_TIMEOUT_SECONDS=60

LLM_MODEL=qwen-1_5b
LLM_DEVICE=auto
BASE_MODELS_DIR=./backend/models

RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_CHUNK_CHARS=800
RAG_CHUNK_OVERLAP=120
RAG_MIN_SCORE=0.25
RAG_FETCH_K=12
RAG_MMR_LAMBDA=0.7

CORS_ORIGINS=http://localhost:5173,http://localhost:3000

DATA_FILE=backend/bombas_higra.parquet
MAX_PARALELO=4
MAX_SERIE=4

# Importacao teste bancada
# Apenas SOURCE_URL precisa ser informado para habilitar a rotina.
# As demais variáveis abaixo são opcionais e possuem default.
IMPORTACAO_TESTE_BANCADA_ENABLED=true
IMPORTACAO_TESTE_BANCADA_TIMEZONE=America/Sao_Paulo
IMPORTACAO_TESTE_BANCADA_HOUR=2
IMPORTACAO_TESTE_BANCADA_MINUTE=0
SOURCE_URL=
REQUEST_TIMEOUT_MS=30000
FETCH_MAX_ATTEMPTS=3
FETCH_RETRY_BASE_DELAY_MS=1000
PROGRESS_LOG_EVERY=100
